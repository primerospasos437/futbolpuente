# Copiá a .env y completá con tu proyecto (Supabase Dashboard → Settings → API).
# Para la web pública: estas variables tienen que existir al ejecutar `npm run build`
# (por ejemplo en GitHub Actions → Secrets), no pueden ser 127.0.0.1.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo para el servidor Express opcional (npm run dev:server)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_secreta
