# === Uso normal (todo en la nube) ===
# 1) cp .env.example .env
# 2) Supabase → Project Settings → API → copiá "Project URL" y "anon public"
# 3) Pegá abajo. NO uses 127.0.0.1:54321 salvo que desarrolles con `supabase start`.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_publica

# Solo si corrés el backend Express local (npm run dev con server):
# SUPABASE_URL=https://TU-PROYECTO.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_secreta
