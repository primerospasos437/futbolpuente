# Copiá este archivo a `.env` y completá con tu proyecto (Supabase → Settings → API).
#
# IMPORTANTE: `http://127.0.0.1:54321` solo sirve si tenés Supabase CLI con `supabase start`
# corriendo en tu máquina. Para el grupo en internet usá siempre la URL https://….supabase.co

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_publica

# Solo para el servidor Node local (carpeta server/), no para Vite:
# SUPABASE_URL=https://TU-PROYECTO.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_secreta
